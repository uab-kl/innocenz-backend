{
  "name": "innocenz-backend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --clear-screen=false src/main.ts src/**/*.ts",
    "start": "node dist/main.js",
    "build": "esbuild src/main.ts --bundle --platform=node --target=node22 --minify --format=esm --outfile=dist/main.js --packages=external --alias:@=./src --alias:graphql/error=graphql/error/index.js",
    "migrate": "drizzle-kit generate && drizzle-kit migrate",
    "migrate:deploy": "drizzle-kit migrate --config=drizzle.migrate.config.ts",
    "initialize": "node scripts/setup-env.mjs",
    "db:reset": "node scripts/reset-migrations.mjs && drizzle-kit migrate --config=drizzle.migrate.config.ts",
    "db:seed": "node scripts/seed-admin.mjs",
    "test": "vitest"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.0.9",
    "@types/pg": "^8.16.0",
    "drizzle-kit": "^0.31.8",
    "esbuild": "^0.27.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^6.0.4",
    "vitest": "^4.0.17"
  },
  "dependencies": {
    "@apollo/server": "^5.3.0",
    "@as-integrations/express5": "^1.1.2",
    "@graphql-tools/merge": "^9.1.7",
    "@graphql-tools/schema": "^10.0.31",
    "@graphql-tools/utils": "^11.0.0",
    "@t3-oss/env-core": "^0.13.10",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "graphql": "^16.12.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.17.2",
    "winston": "^3.19.0",
    "zod": "^4.3.5"
  },
  "_moduleAliases": {
    "@": "src"
  }
}
